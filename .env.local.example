# Supabase (required for Inspiration uploads and leaderboard)
# See docs/SUPABASE_SETUP.md and docs/SUPABASE_AUTH_SETUP.md for setup steps.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_public_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Google Gemini API (optional, for AI suggestions)
GEMINI_API_KEY=your_gemini_api_key

# Admin Configuration (optional)
ADMIN_EMAILS=admin@example.com,admin2@example.com

# Vercel Cron Secret (optional)
VERCEL_CRON_SECRET=your_cron_secret

# Optional: protect seed endpoint
# INSPIRATIONS_SEED_SECRET=your_secret
